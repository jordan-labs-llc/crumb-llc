<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Template for UCP credentials. Copy this file to `Secrets.plist` (which is gitignored)
  and fill in real values to run against a live UCP backend.

  The scaffold runs entirely on MockUCPClient and does NOT require this file — a missing
  Secrets.plist resolves to UCPConfig.mock. Global Catalog search is GA (API key only);
  native in-agent checkout requires Shopify opt-in; Universal Cart is early access.
-->
<plist version="1.0">
<dict>
    <key>UCP_BASE_URL</key>
    <string>https://catalog.example.invalid/ucp</string>
    <key>UCP_API_KEY</key>
    <string>REPLACE_WITH_UCP_API_KEY</string>
</dict>
</plist>
