<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Template for the Crumb broker connection. Copy this file to `Secrets.plist` (gitignored)
  and set CRUMB_API_BASE_URL to point the app at your deployed broker (crumb-llc-api).

  There is NO Shopify secret on the device (App Store rule 5.9): the broker holds the
  Shopify UCP credentials server-side. The only values here are the broker's base URL and
  an OPTIONAL broker access key (sent as the x-broker-key header — rotatable, broker-scoped).

  With no Secrets.plist, the app resolves to UCPConfig.mock and runs entirely on
  MockUCPClient — no network required.
-->
<plist version="1.0">
<dict>
    <key>CRUMB_API_BASE_URL</key>
    <string>https://func-crumb-agent-xxxxxx.azurewebsites.net</string>
    <key>CRUMB_API_KEY</key>
    <string></string>
</dict>
</plist>
