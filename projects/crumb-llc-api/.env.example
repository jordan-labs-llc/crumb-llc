# Local dev configuration for the broker. Copy to `.env` (gitignored) and fill in.
# In Azure these are Container App env vars; the two secrets resolve from Key Vault.

SHOPIFY_UCP_CLIENT_ID=your-dev-dashboard-client-id
SHOPIFY_UCP_CLIENT_SECRET=your-dev-dashboard-client-secret
SHOPIFY_CATALOG_URL=https://paste-the-catalog-mcp-url-from-dev-dashboard
SHOPIFY_TOKEN_URL=https://api.shopify.com/auth/access_token
UCP_VERSION=2026-04-08

# Public URL Shopify can fetch to negotiate your agent profile. Required by `make verify`
# (a local/localhost value is rejected by Shopify). Point it at your deployed broker:
#   https://ca-crumb-agent-dev.<region>.azurecontainerapps.io/.well-known/ucp
AGENT_PROFILE_URL=

# Optional: require this value as the `x-broker-key` header on catalog routes.
CRUMB_BROKER_KEY=
